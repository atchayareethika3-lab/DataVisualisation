import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load dataset
df = pd.read_csv("automobile_sales_data.csv")

# Basic styling
sns.set(style="whitegrid")

#1.1 Line Chart – Yearly Sales Fluctuation
plt.figure(figsize=(8,5))
plt.plot(df.groupby('Year')['Automobile_Sales'].sum())

plt.title("Yearly Automobile Sales Trend")
plt.xlabel("Year")
plt.ylabel("Total Sales")
plt.show()

#1.2 Advertising vs Sales (Non-Recession)
non_recession = df[df['Recession'] == 0]

plt.figure(figsize=(8,5))
plt.plot(non_recession['Year'], non_recession['Advertising_Expenditure'], label='Ad Spend')
plt.plot(non_recession['Year'], non_recession['Automobile_Sales'], label='Sales')

plt.legend()
plt.title("Advertising vs Sales (Non-Recession)")
plt.show()
#1.3 Bar Chart – Vehicle Type Comparison
recession = df[df['Recession'] == 1]
non_recession = df[df['Recession'] == 0]

rec_sales = recession.groupby('Vehicle_Type')['Automobile_Sales'].mean()
nonrec_sales = non_recession.groupby('Vehicle_Type')['Automobile_Sales'].mean()

rec_sales.plot(kind='bar', alpha=0.7, label='Recession')
nonrec_sales.plot(kind='bar', alpha=0.7, label='Non-Recession')

plt.legend()
plt.title("Sales by Vehicle Type")
plt.show()

#1.4 Subplots – GDP Comparison

fig, ax = plt.subplots(1,2, figsize=(12,5))

sns.lineplot(data=recession, x='Year', y='GDP', ax=ax[0])
ax[0].set_title("GDP During Recession")

sns.lineplot(data=non_recession, x='Year', y='GDP', ax=ax[1])
ax[1].set_title("GDP During Non-Recession")

plt.show()

#1.5 Bubble Plot – Seasonality Impact

plt.figure(figsize=(8,5))

plt.scatter(df['Month'], df['Automobile_Sales'], 
            s=df['Automobile_Sales']/10, alpha=0.5)

plt.title("Seasonality Impact on Sales")
plt.xlabel("Month")
plt.ylabel("Sales")
plt.show()

#1.6 Scatter Plot – Price vs Sales (Recession)
plt.figure(figsize=(8,5))

sns.scatterplot(data=recession, 
                x='Average_Vehicle_Price', 
                y='Automobile_Sales')

plt.title("Price vs Sales During Recession")
plt.show()

#1.7 Pie Chart – Ad Expenditure (Recession vs Non)
ad_data = df.groupby('Recession')['Advertising_Expenditure'].sum()

plt.pie(ad_data, labels=['Non-Recession','Recession'], autopct='%1.1f%%')
plt.title("Ad Expenditure Share")
plt.show()

#1.8 Pie Chart – Ad Spend by Vehicle Type (Recession)
rec_ad = recession.groupby('Vehicle_Type')['Advertising_Expenditure'].sum()

plt.pie(rec_ad, labels=rec_ad.index, autopct='%1.1f%%')
plt.title("Ad Spend by Vehicle Type (Recession)")
plt.show()

#1.9 Line Chart – Unemployment Effect

plt.figure(figsize=(8,5))

sns.lineplot(data=recession, 
             x='Unemployment_Rate', 
             y='Automobile_Sales', 
             hue='Vehicle_Type')

plt.title("Unemployment vs Sales (Recession)")
plt.show()
